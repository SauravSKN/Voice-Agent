# Copy this file to .env. The PowerShell scripts load it without overriding
# environment variables that are already set in the current process.

# Speech-to-Text: reliable CPU defaults
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_ALLOW_CPU_FALLBACK=true

# Local language model
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b-instruct
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MAX_TOKENS=160
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=60
LLM_MAX_INPUT_CHARS=2000
LLM_MAX_RESPONSE_CHARS=500
LLM_CONTEXT_TOKENS=4096
LLM_KEEP_ALIVE=5m
LLM_MAX_HISTORY_MESSAGES=12

# Temporary, process-local conversation memory
CONVERSATION_MAX_TURNS=6
CONVERSATION_TTL_MINUTES=30
CONVERSATION_MAX_SESSIONS=100

# Local Text-to-Speech
TTS_PROVIDER=piper
TTS_MODEL=models/piper/hi_IN-priyamvada-medium.onnx
TTS_DEVICE=cpu
TTS_OUTPUT_FORMAT=wav
TTS_MAX_INPUT_CHARS=500
TTS_ALLOW_CPU_FALLBACK=true
TTS_TIMEOUT_SECONDS=60
TTS_OUTPUT_TTL_MINUTES=60
TTS_MAX_OUTPUT_FILES=50
TTS_ALLOW_PIPER_FALLBACK=true

# Optional natural Hindi provider. It runs in the isolated loopback worker.
INDIC_PARLER_MODEL=ai4bharat/indic-parler-tts
INDIC_PARLER_SERVICE_URL=http://127.0.0.1:8002
INDIC_PARLER_DEVICE=cuda
INDIC_PARLER_DTYPE=float16
INDIC_PARLER_SPEAKER=Divya
INDIC_PARLER_MAX_INPUT_CHARS=500
INDIC_PARLER_TIMEOUT_SECONDS=90
INDIC_PARLER_ALLOW_CPU_FALLBACK=false
INDIC_PARLER_DESCRIPTION=Divya speaks in a warm, natural and conversational Hindi voice. Her pace is moderate, her pitch is balanced, and her speech is slightly expressive. The recording is clear and close, with no background noise.
